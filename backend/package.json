{
  "name": "mollmart-backend",
  "version": "1.0.0",
  "description": "Mollmart modular monolith backend",
  "private": true,
  "main": "./dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development ts-node --files src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "npm run build && cross-env NODE_ENV=production node dist/index.js",
    "test": "jest --runInBand",
    "coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node --files --project tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "argon2": "^0.30.3",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^8.1.0",
    "http-status": "^1.8.1",
    "ioredis": "^5.6.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.1",
    "utility-types": "^3.10.0",
    "uuid": "^9.0.0",
    "winston": "^3.17.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@types/argon2": "^0.15.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.14",
    "@types/nodemailer": "^6.4.7",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.1",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prisma": "^6.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
