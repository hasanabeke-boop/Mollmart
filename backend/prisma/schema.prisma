generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  buyer
  seller
  admin
}

enum UserStatus {
  active
  blocked
  suspended
}

enum VerificationStatus {
  unverified
  pending
  verified
  rejected
}

enum RequestStatus {
  draft
  published
  has_offers
  in_negotiation
  accepted
  closed
  cancelled
}

enum RequestStatusHistoryAction {
  created
  updated
  published
  moved_to_has_offers
  moved_to_negotiation
  accepted
  closed
  cancelled
}

enum OfferStatus {
  submitted
  updated
  withdrawn
  accepted
  rejected
  expired
}

enum OfferStatusHistoryAction {
  created
  updated
  withdrawn
  accepted
  rejected
  expired
}

enum ConversationStatus {
  active
  closed
}

enum MessageType {
  text
  system
}

enum SenderRole {
  buyer
  seller
  admin
}

enum ModerationTargetType {
  request
  offer
  user
}

enum ModerationCaseStatus {
  open
  in_review
  resolved
  dismissed
}

enum ModerationActionType {
  note
  hide_content
  unhide_content
  block_user
  unblock_user
  resolve_case
}

enum ContentFlagStatus {
  active
  hidden
  cleared
}

enum NotificationType {
  request_published
  offer_created
  offer_accepted
  chat_message_created
  user_blocked
  moderation_case_created
}

enum NotificationReferenceType {
  request
  offer
  conversation
  user
  moderation_case
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expiresAt         DateTime
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id                     String                   @id @default(cuid())
  name                   String
  email                  String?                  @unique
  password               String
  role                   UserRole                 @default(buyer)
  status                 UserStatus               @default(active)
  emailVerified          DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  lastLoginAt            DateTime?
  accounts               Account[]
  refreshTokens          RefreshToken[]
  resetToken             ResetToken[]
  emailVerificationToken EmailVerificationToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model ResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model UserProfile {
  id            String         @id @default(cuid())
  userId        String         @unique
  role          UserRole
  fullName      String
  phone         String?
  city          String?
  avatarUrl     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sellerProfile SellerProfile?
  buyerProfile  BuyerProfile?

  @@index([role, createdAt(sort: Desc)])
}

model SellerProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  displayName         String
  description         String?            @db.Text
  businessType        String?
  website             String?
  instagramUrl        String?
  verificationStatus  VerificationStatus @default(unverified)
  ratingAverage       Decimal            @default(0) @db.Decimal(3, 2)
  completedDealsCount Int                @default(0)
  userProfile         UserProfile        @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([verificationStatus, ratingAverage(sort: Desc)])
}

model BuyerProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  displayName     String
  city            String?
  preferencesJson Json?
  userProfile     UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Request {
  id            String                 @id @default(cuid())
  buyerId       String
  title         String
  description   String                 @db.Text
  categoryId    String
  budgetMin     Decimal?               @db.Decimal(12, 2)
  budgetMax     Decimal?               @db.Decimal(12, 2)
  currency      String                 @db.VarChar(3)
  location      String?
  deadlineAt    DateTime?
  status        RequestStatus          @default(draft)
  offerCount    Int                    @default(0)
  isNegotiable  Boolean                @default(false)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  publishedAt   DateTime?
  closedAt      DateTime?
  attachments   RequestAttachment[]
  statusHistory RequestStatusHistory[]

  @@index([buyerId, createdAt(sort: Desc)])
  @@index([status, publishedAt(sort: Desc)])
  @@index([categoryId, status])
  @@index([deadlineAt])
}

model RequestAttachment {
  id        String   @id @default(cuid())
  requestId String
  fileName  String
  fileUrl   String
  mimeType  String?
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model RequestStatusHistory {
  id         String                     @id @default(cuid())
  requestId  String
  fromStatus RequestStatus?
  toStatus   RequestStatus
  action     RequestStatusHistoryAction
  actorId    String
  note       String?
  createdAt  DateTime                   @default(now())
  request    Request                    @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt(sort: Desc)])
}

model Offer {
  id            String               @id @default(cuid())
  requestId     String
  sellerId      String
  price         Decimal              @db.Decimal(12, 2)
  currency      String               @db.VarChar(3)
  message       String               @db.Text
  deliveryDays  Int?
  warrantyInfo  String?              @db.Text
  status        OfferStatus          @default(submitted)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  acceptedAt    DateTime?
  withdrawnAt   DateTime?
  statusHistory OfferStatusHistory[]

  @@index([requestId, createdAt(sort: Desc)])
  @@index([sellerId, createdAt(sort: Desc)])
  @@index([requestId, status])
}

model OfferStatusHistory {
  id         String                   @id @default(cuid())
  offerId    String
  fromStatus OfferStatus?
  toStatus   OfferStatus
  action     OfferStatusHistoryAction
  actorId    String
  note       String?
  createdAt  DateTime                 @default(now())
  offer      Offer                    @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId, createdAt(sort: Desc)])
}

model Conversation {
  id            String             @id @default(cuid())
  requestId     String
  offerId       String?
  buyerId       String
  sellerId      String
  status        ConversationStatus @default(active)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  lastMessageAt DateTime?
  messages      Message[]

  @@unique([requestId, buyerId, sellerId])
  @@index([buyerId, lastMessageAt(sort: Desc)])
  @@index([sellerId, lastMessageAt(sort: Desc)])
}

model Message {
  id             String             @id @default(cuid())
  conversationId String
  senderId       String
  senderRole     SenderRole
  body           String             @db.Text
  messageType    MessageType        @default(text)
  createdAt      DateTime           @default(now())
  conversation   Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  readStates     MessageReadState[]

  @@index([conversationId, createdAt(sort: Desc)])
}

model MessageReadState {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt(sort: Desc)])
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  parentId  String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")

  @@index([parentId])
  @@index([isActive, createdAt(sort: Desc)])
}

model ModerationCase {
  id             String               @id @default(cuid())
  targetType     ModerationTargetType
  targetId       String
  reason         String               @db.Text
  status         ModerationCaseStatus @default(open)
  createdBy      String
  assignedTo     String?
  resolutionNote String?              @db.Text
  createdAt      DateTime             @default(now())
  resolvedAt     DateTime?
  actions        ModerationAction[]

  @@index([targetType, targetId])
  @@index([status, createdAt(sort: Desc)])
}

model ModerationAction {
  id               String               @id @default(cuid())
  moderationCaseId String
  actionType       ModerationActionType
  actorId          String
  note             String?              @db.Text
  createdAt        DateTime             @default(now())
  moderationCase   ModerationCase       @relation(fields: [moderationCaseId], references: [id], onDelete: Cascade)

  @@index([moderationCaseId, createdAt(sort: Desc)])
}

model BlockedUser {
  id          String   @id @default(cuid())
  userId      String   @unique
  reason      String   @db.Text
  blockedBy   String
  blockedAt   DateTime @default(now())
  unblockedAt DateTime?
}

model ContentFlag {
  id         String               @id @default(cuid())
  targetType ModerationTargetType
  targetId   String
  reason     String               @db.Text
  status     ContentFlagStatus    @default(active)
  createdBy  String
  hiddenBy   String?
  hiddenAt   DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([targetType, targetId])
  @@index([status, createdAt(sort: Desc)])
}

model Notification {
  id            String                    @id @default(cuid())
  userId        String
  type          NotificationType
  title         String
  body          String                    @db.Text
  referenceType NotificationReferenceType
  referenceId   String
  dedupeKey     String?                   @unique
  isRead        Boolean                   @default(false)
  createdAt     DateTime                  @default(now())
  readAt        DateTime?

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead, createdAt(sort: Desc)])
}
