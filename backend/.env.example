NODE_ENV=development
PORT=4040
SERVER_URL=http://localhost:4040
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres123@localhost:54320/mollmart?schema=public
POSTGRES_PORT=54320
POSTGRES_DB=mollmart
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

JWT_ACCESS_SECRET=change-me-shared-access-secret
JWT_REFRESH_SECRET=change-me-shared-refresh-secret
ACCESS_TOKEN_EXPIRE=20m
REFRESH_TOKEN_EXPIRE=1d
REFRESH_TOKEN_COOKIE_NAME=jid
INTERNAL_API_TOKEN=

REDIS_URL=redis://localhost:6380
REDIS_PORT=6380
REDIS_ENABLED=true

DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
ALLOW_MULTIPLE_ACTIVE_OFFERS_PER_REQUEST=false
SUBSCRIBE_MODERATION_EVENTS=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=password
EMAIL_FROM=no-reply@example.com
