{
  "name": "mollmart-offer-service",
  "version": "1.0.0",
  "description": "Offer service for the Mollmart reverse auction marketplace backend",
  "private": true,
  "main": "./dist/src/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsc --project tsconfig.build.json --watch && cross-env NODE_ENV=development nodemon --trace-warnings ./dist/src/index.js",
    "build": "tsc --project tsconfig.build.json",
    "start": "npm run build && cross-env NODE_ENV=production node --trace-warnings ./dist/src/index.js",
    "watch": "tsc --project tsconfig.build.json --watch",
    "test": "jest --runInBand",
    "coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node --project tsconfig.test.json prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.test.json prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "http-status": "^1.8.1",
    "ioredis": "^5.6.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.14",
    "@types/supertest": "^6.0.3",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prisma": "^6.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
